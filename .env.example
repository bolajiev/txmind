# Solana RPC
RPC_ENDPOINT=https://api.devnet.solana.com
# Or mainnet: https://api.mainnet-beta.solana.com

# Yellowstone gRPC (Helius LaserStream — Yellowstone-compatible)
YELLOWSTONE_ENDPOINT=https://laserstream-devnet-ewr.helius-rpc.com
YELLOWSTONE_TOKEN=your-helius-api-key

# Jito Block Engine (mainnet only; devnet submission uses RPC)
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf

# Wallet (base58 private key — use a throwaway devnet wallet)
WALLET_PRIVATE_KEY=your-base58-private-key

# Qwen AI Agent (DashScope OpenAI-compatible API)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Run config
NETWORK=devnet
SUBMISSION_COUNT=10
MAX_RETRY_ATTEMPTS=3
